# ─── REDLINE Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ─── Rails ────────────────────────────────────────────────────────────────
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=your-secret-key-base-here
RAILS_ENV=production

# SSL / TLS — only change if you know what you're doing
# RAILS_ASSUME_SSL=false  (default: false — works without a reverse proxy out of the box)
#                         Set to true only if behind a TLS-terminating proxy that does NOT
#                         set the X-Forwarded-Proto header. Most proxies (Nginx, Caddy,
#                         Traefik) set it automatically, so you rarely need this.
# RAILS_FORCE_SSL=false   (default: false — let the reverse proxy handle HTTPS redirects)

# ─── Database ─────────────────────────────────────────────────────────────
POSTGRES_DB=redline
POSTGRES_USER=redline
POSTGRES_PASSWORD=change-me-strong-password

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ─── LiveKit ──────────────────────────────────────────────────────────────
# LiveKit server URL (ws:// for internal, wss:// for external with TLS)
LIVEKIT_URL=ws://livekit:7880
# Generate with: openssl rand -hex 16
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ─── Email ────────────────────────────────────────────────────────────────
DEVISE_MAILER_FROM=redline@yourdomain.com

# ─── OAuth (optional) ────────────────────────────────────────────────────
# GitHub OAuth — https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
#
# Steam Web API — https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# ─── Privacy ─────────────────────────────────────────────────────────────
# Set to "true" to include IP addresses in audit logs
# AUDIT_LOG_IPS=false

# ─── Port ─────────────────────────────────────────────────────────────────
PORT=3000
