<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#000000">
    <title><%= content_for?(:title) ? "#{yield :title} · Admin · REDLINE" : "Admin · REDLINE" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div style="display:flex;height:100vh;overflow:hidden">
      <%# Admin Sidebar %>
      <nav style="width:14rem;background:var(--rl-surface);border-right:1px solid var(--rl-border);display:flex;flex-direction:column;flex-shrink:0"
           aria-label="Admin navigation">
        <div style="height:3.5rem;display:flex;align-items:center;padding:0 1rem;border-bottom:1px solid var(--rl-border)">
          <%= link_to admin_dashboard_path,
                style: "font-weight:700;font-size:1rem;color:var(--rl-accent);text-decoration:none;display:flex;align-items:center;gap:.5rem" do %>
            <svg aria-hidden="true" width="24" height="24" viewBox="0 0 32 32" fill="none">
              <rect width="32" height="32" rx="8" fill="var(--rl-surface-elevated)"/>
              <text x="6" y="23" font-family="system-ui,sans-serif" font-weight="700" font-size="18" fill="var(--rl-accent)">R</text>
              <text x="17" y="23" font-family="system-ui,sans-serif" font-weight="700" font-size="18" fill="var(--rl-text-primary)">L</text>
            </svg>
            Admin
          <% end %>
        </div>

        <div style="flex:1;padding:.5rem;overflow-y:auto">
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.125rem">
            <li>
              <%= link_to "Dashboard", admin_dashboard_path,
                    class: "nav-item",
                    style: "display:flex;align-items:center;gap:.5rem" %>
            </li>
            <li>
              <%= link_to "Users", admin_users_path,
                    class: "nav-item",
                    style: "display:flex;align-items:center;gap:.5rem" %>
            </li>
            <li>
              <%= link_to "Rooms", admin_rooms_path,
                    class: "nav-item",
                    style: "display:flex;align-items:center;gap:.5rem" %>
            </li>
            <li>
              <%= link_to "Audit Logs", admin_audit_logs_path,
                    class: "nav-item",
                    style: "display:flex;align-items:center;gap:.5rem" %>
            </li>
            <li>
              <%= link_to "Invites", admin_invites_path,
                    class: "nav-item",
                    style: "display:flex;align-items:center;gap:.5rem" %>
            </li>
            <li>
              <%= link_to "System Health", admin_system_path,
                    class: "nav-item",
                    style: "display:flex;align-items:center;gap:.5rem" %>
            </li>
            <li>
              <%= link_to "Settings", admin_settings_path,
                    class: "nav-item",
                    style: "display:flex;align-items:center;gap:.5rem" %>
            </li>
          </ul>
        </div>

        <div style="border-top:1px solid var(--rl-border);padding:.75rem;font-size:.75rem">
          <%= link_to "← Back to REDLINE", rooms_path, style: "color:var(--rl-text-muted);text-decoration:none" %>
        </div>
      </nav>

      <%# Main Content %>
      <main style="flex:1;overflow-y:auto;padding:1.5rem 2rem">
        <% if notice %>
          <div role="status" class="flash flash-notice" style="margin-bottom:1rem"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div role="alert" class="flash flash-alert" style="margin-bottom:1rem"><%= alert %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
