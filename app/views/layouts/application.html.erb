<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#000000">
    <meta name="description" content="REDLINE — Privacy-first, self-hosted real-time communication">
    <title><%= content_for?(:title) ? "#{yield :title} · REDLINE" : "REDLINE" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <% if ENV["VAPID_PUBLIC_KEY"].present? %>
      <meta name="vapid-public-key" content="<%= ENV['VAPID_PUBLIC_KEY'] %>">
    <% end %>
    <%= javascript_importmap_tags %>
    <script>
      // Register service worker for PWA support
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {})
        })
      }
    </script>
  </head>

  <body data-link-previews="<%= link_previews_body_attr %>"
        data-dm-sounds="<%= current_user&.notification_preference&.dm_sounds != false ? 'true' : 'false' %>"
        data-mention-alerts="<%= current_user&.notification_preference&.mention_alerts != false ? 'true' : 'false' %>">
    <%# Skip navigation link — first focusable element, visible on focus %>
    <a href="#main-content" aria-label="Skip to main content">Skip to main content</a>

    <% if user_signed_in? %>
      <%# App Shell — sidebar controller on root so hamburger buttons anywhere in the tree can trigger it %>
      <div role="application" aria-label="REDLINE application" data-controller="sidebar new-dm" style="display:flex;height:100vh;overflow:hidden">

        <%# Mobile sidebar overlay/backdrop %>
        <div id="sidebar-backdrop"
             class="sidebar-backdrop"
             data-action="click->sidebar#close"
             aria-hidden="true"></div>

        <%# Sidebar %>
        <nav id="sidebar" aria-label="Main navigation">
          <%# Brand %>
          <div style="height:3.5rem;display:flex;align-items:center;padding:0 1rem;border-bottom:1px solid var(--rl-border);flex-shrink:0">
            <%= link_to rooms_path,
                  style: "display:flex;align-items:center;gap:.5rem;font-weight:700;font-size:1.125rem;letter-spacing:.05em;text-decoration:none;border-radius:4px",
                  aria: { label: "REDLINE home" } do %>
              <svg aria-hidden="true" width="24" height="24" viewBox="0 0 32 32" fill="none">
                <rect width="32" height="32" rx="8" fill="var(--rl-surface-elevated)"/>
                <text x="6" y="23" font-family="system-ui,sans-serif" font-weight="700" font-size="18" fill="#e53e3e">R</text>
                <text x="17" y="23" font-family="system-ui,sans-serif" font-weight="700" font-size="18" fill="#f0f2f7">L</text>
              </svg>
              <%= redline_brand_text %>
            <% end %>
          </div>

          <%# Search trigger (hidden — will revisit later) %>

          <%# Nav content %>
          <div class="scroll-area" style="flex:1;padding:.5rem 0">
            <%
              # Categorise user's top-level rooms
              user_rooms   = current_user.rooms.top_level.by_position.includes(:subchannels, :category)
              announcement_rooms = user_rooms.select { |r| r.announcement? }
              private_rooms = user_rooms.select { |r| (r.private? || r.e2ee?) && !r.announcement? }
              voice_rooms   = user_rooms.select { |r| r.voice_channel? && !r.private? && !r.e2ee? && !r.announcement? }
              chat_rooms    = user_rooms.select { |r| r.chat? && !r.voice_channel? && !r.private? && !r.e2ee? && !r.announcement? }

              # Group public chat/voice rooms by category
              categorised_rooms = (voice_rooms + chat_rooms).group_by { |r| r.category }
              # Sort: named categories by position then name, nil (uncategorised) last
              sorted_categories = categorised_rooms.keys.sort_by { |c| c ? [0, c.position.to_i, c.name] : [1, 0, ""] }
            %>

            <%# Announcements — pinned to the top %>
            <% if announcement_rooms.any? %>
              <section aria-labelledby="nav-announcements-heading">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.25rem .75rem">
                  <h2 id="nav-announcements-heading" class="nav-section-heading" style="margin:0">Announcements <span aria-hidden="true">📢</span></h2>
                </div>
                <ul role="list" style="margin:.25rem 0 0;padding:0 .5rem;list-style:none">
                  <% announcement_rooms.each do |room| %>
                    <li>
                      <%= link_to room_path(room),
                            class: "nav-item #{"active" if @room&.slug == room.slug}",
                            data: { room_slug: room.slug },
                            aria: { current: @room&.slug == room.slug ? "page" : nil,
                                    label: "Announcement: #{room.name}" } do %>
                        <span aria-hidden="true" style="flex-shrink:0"><%= room.display_icon %></span>
                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= room.name %></span>
                      <% end %>
                      <div class="nav-room-viewers hidden" data-room-slug="<%= room.slug %>" aria-label="Active viewers"></div>
                    </li>
                  <% end %>
                </ul>
              </section>
            <% end %>

            <%# Private channels/chats — shown first %>
            <% if private_rooms.any? %>
              <section aria-labelledby="nav-private-heading" style="<%= 'margin-top:1rem' if announcement_rooms.any? %>">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.25rem .75rem">
                  <h2 id="nav-private-heading" class="nav-section-heading" style="margin:0">Private <span aria-hidden="true">🗝️🔐</span></h2>
                </div>
                <ul role="list" style="margin:.25rem 0 0;padding:0 .5rem;list-style:none">
                  <% private_rooms.each do |room| %>
                    <li>
                      <%= link_to room_path(room),
                            class: "nav-item #{"active" if @room&.slug == room.slug}",
                            data: { room_slug: room.slug },
                            aria: { current: @room&.slug == room.slug ? "page" : nil,
                                    label: "Private #{room.voice_channel? ? 'Channel' : 'Chat'}: #{room.name}" } do %>
                        <span aria-hidden="true" style="flex-shrink:0"><%= room.display_icon %></span>
                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= room.name %></span>
                      <% end %>
                      <div class="nav-room-viewers hidden" data-room-slug="<%= room.slug %>" aria-label="Active viewers"></div>
                    </li>
                  <% end %>
                </ul>
              </section>
            <% end %>

            <%# Channels & Chats — grouped by category (uncategorised rooms appear under their type heading) %>
            <% has_above = private_rooms.any? || announcement_rooms.any? %>
            <% sorted_categories.each_with_index do |category, idx| %>
              <% rooms_in_cat = categorised_rooms[category] %>
              <% cat_id = category ? "nav-cat-#{category.id}-heading" : "nav-channels-heading" %>
              <% cat_label = category ? category.name : "Channels" %>
              <section aria-labelledby="<%= cat_id %>" style="<%= 'margin-top:1rem' if idx > 0 || has_above %>">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.25rem .75rem">
                  <h2 id="<%= cat_id %>" class="nav-section-heading" style="margin:0"><%= cat_label %></h2>
                  <% if idx == 0 && !category %>
                    <%= link_to new_room_path,
                          style: "color:var(--rl-text-muted);display:flex;border-radius:4px",
                          aria: { label: "Create new channel" } do %>
                      <svg aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                      </svg>
                    <% end %>
                  <% end %>
                </div>
                <ul role="list" style="margin:.25rem 0 0;padding:0 .5rem;list-style:none">
                  <% rooms_in_cat.each do |room| %>
                    <li>
                      <%= link_to room_path(room),
                            class: "nav-item #{"active" if @room&.slug == room.slug}",
                            data: { room_slug: room.slug },
                            aria: { current: @room&.slug == room.slug ? "page" : nil,
                                    label: "#{room.voice_channel? ? 'Channel' : 'Chat'}: #{room.name}" } do %>
                        <span aria-hidden="true" style="flex-shrink:0"><%= room.display_icon %></span>
                        <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= room.name %></span>
                      <% end %>
                      <div class="nav-room-viewers hidden" data-room-slug="<%= room.slug %>" aria-label="Active viewers"></div>
                      <% if room.voice_channel? && room.subchannels.any? %>
                        <ul role="list" style="margin:0;padding:0 0 0 1.25rem;list-style:none">
                          <% room.subchannels.by_position.each do |sub| %>
                            <li>
                              <%= link_to room_path(sub),
                                    class: "nav-item #{"active" if @room&.slug == sub.slug}",
                                    data: { room_slug: sub.slug },
                                    aria: { current: @room&.slug == sub.slug ? "page" : nil,
                                            label: "Subchannel: #{sub.name}" } do %>
                                <span aria-hidden="true" style="flex-shrink:0">🔊</span>
                                <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= sub.name %></span>
                              <% end %>
                              <div class="nav-room-viewers hidden" data-room-slug="<%= sub.slug %>" aria-label="Active viewers"></div>
                            </li>
                          <% end %>
                        </ul>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </section>
            <% end %>

            <%# Direct Messages %>
            <section aria-labelledby="nav-dms-heading" style="margin-top:1.5rem">
              <div style="display:flex;align-items:center;justify-content:space-between;padding:.25rem .75rem">
                <h2 id="nav-dms-heading" class="nav-section-heading" style="margin:0">Direct Messages</h2>
                <button type="button"
                        style="color:var(--rl-text-muted);display:flex;border-radius:4px;border:none;background:transparent;cursor:pointer;padding:.125rem"
                        aria-label="Start a new direct message"
                        title="New direct message"
                        data-action="click->new-dm#open">
                  <svg aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                  </svg>
                </button>
              </div>
              <% dm_partners = (current_user.sent_direct_messages.includes(:recipient).map(&:recipient) +
                                current_user.received_direct_messages.includes(:sender).map(&:sender))
                               .uniq.first(10) %>
              <ul role="list" style="margin:.25rem 0 0;padding:0 .5rem;list-style:none">
                <% dm_partners.each do |partner| %>
                  <% unread_count = @unread_dm_counts[partner.id].to_i %>
                  <li>
                    <%= link_to user_direct_messages_path(partner),
                          class: "nav-item",
                          data: { "dm-partner-id": partner.id },
                          aria: { label: "Direct message with #{partner.display_name}, #{partner.status}#{unread_count > 0 ? ", #{unread_count} unread" : ""}" } do %>
                      <div class="avatar avatar-sm" style="background-color:#{partner.avatar_color}" aria-hidden="true">
                        <%= partner.initials %>
                      </div>
                      <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">
                        <%= partner.display_name %>
                      </span>
                      <% if unread_count > 0 %>
                        <span class="dm-unread-badge" aria-label="<%= unread_count %> unread"><%= unread_count > 99 ? "99+" : unread_count %></span>
                      <% elsif partner.online? %>
                        <span class="status-dot status-online" aria-label="online" style="flex-shrink:0"></span>
                      <% end %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </section>
          </div>

          <%# User info footer %>
          <div style="border-top:1px solid var(--rl-border);padding:.75rem;display:flex;flex-direction:column;gap:.5rem;flex-shrink:0">
            <% if current_user.admin? %>
              <div style="padding-bottom:.5rem;border-bottom:1px solid var(--rl-border)">
                <%= link_to admin_dashboard_path,
                      style: "font-size:.75rem;color:var(--rl-accent);text-decoration:none;display:flex;align-items:center;gap:.25rem",
                      aria: { label: "Admin Dashboard" } do %>
                  ⚙️ Admin Dashboard
                <% end %>
              </div>
            <% end %>
            <div style="display:flex;align-items:center;gap:.75rem">
              <div class="avatar avatar-md" style="background-color:<%= current_user.avatar_color %>" aria-hidden="true">
                <%= current_user.initials %>
              </div>
              <%# Status picker dropdown %>
              <div class="status-picker" style="flex:1;min-width:0" data-controller="status-picker">
                <button type="button"
                        class="status-picker-trigger"
                        aria-haspopup="listbox"
                        aria-label="Change status, currently <%= current_user.status %>"
                        data-action="click->status-picker#toggle">
                  <p style="font-size:.875rem;font-weight:500;color:var(--rl-text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                    <%= current_user.display_name %>
                  </p>
                  <p style="font-size:.75rem;color:var(--rl-text-muted);display:flex;align-items:center;gap:.25rem">
                    <span class="status-dot status-<%= current_user.status %>" data-status-picker-target="dot" aria-hidden="true"></span>
                    <span data-status-picker-target="label" style="text-transform:capitalize"><%= current_user.status %></span>
                  </p>
                </button>
                <div class="status-picker-dropdown hidden" data-status-picker-target="dropdown" role="listbox" aria-label="Select status">
                  <button class="status-option" data-action="click->status-picker#select" data-status="online" role="option">
                    <span class="status-dot status-online" aria-hidden="true"></span> Online
                  </button>
                  <button class="status-option" data-action="click->status-picker#select" data-status="away" role="option">
                    <span class="status-dot status-away" aria-hidden="true"></span> Away
                  </button>
                  <button class="status-option" data-action="click->status-picker#select" data-status="busy" role="option">
                    <span class="status-dot status-busy" aria-hidden="true"></span> Busy
                  </button>
                  <button class="status-option" data-action="click->status-picker#select" data-status="offline" role="option">
                    <span class="status-dot status-offline" aria-hidden="true"></span> Offline
                  </button>
                </div>
              </div>
              <%= link_to edit_user_registration_path,
                    class: "btn-icon",
                    aria: { label: "Account settings" } do %>
                <svg aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              <% end %>
              <%= button_to destroy_user_session_path,
                    method: :delete,
                    class: "btn-icon",
                    style: "color:var(--rl-text-muted)",
                    aria: { label: "Sign out of REDLINE" },
                    form: { "data-turbo": "false" } do %>
                <svg aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
              <% end %>
            </div>
          </div>

          <%# Push notification opt-in banner — shown once per session if permission not yet granted %>
          <% if ENV["VAPID_PUBLIC_KEY"].present? %>
            <div class="hidden"
                 style="padding:.5rem .75rem;border-top:1px solid var(--rl-border);flex-shrink:0"
                 data-controller="push-optin"
                 data-push-optin-vapid-key-value="<%= ENV['VAPID_PUBLIC_KEY'] %>"
                 role="complementary"
                 aria-label="Notification opt-in">
              <div style="font-size:.75rem;color:var(--rl-text-secondary);margin-bottom:.375rem">
                🔔 Enable push notifications?
              </div>
              <div style="display:flex;gap:.375rem">
                <button type="button"
                        class="btn"
                        style="flex:1;font-size:.75rem;padding:.3rem .5rem;justify-content:center;color:var(--rl-accent)"
                        data-action="click->push-optin#enable">
                  Enable
                </button>
                <button type="button"
                        class="btn-icon"
                        style="font-size:.75rem;color:var(--rl-text-muted)"
                        aria-label="Dismiss notification prompt"
                        data-action="click->push-optin#dismiss">
                  <svg aria-hidden="true" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            </div>
          <% end %>
        </nav>

        <%# New DM user picker modal %>
        <%# Controlled by new-dm on the parent [role=application] div %>
        <div class="new-dm-modal-backdrop hidden"
             aria-modal="true"
             aria-label="Start a direct message"
             role="dialog"
             data-new-dm-target="modal"
             data-action="click->new-dm#closeOnBackdrop keydown->new-dm#keydown">
          <div class="new-dm-modal">
            <div class="new-dm-modal-header">
              <h2 style="font-size:1rem;font-weight:600;color:var(--rl-text-primary)">New Direct Message</h2>
              <button type="button" class="btn-icon" aria-label="Close" data-action="click->new-dm#close">
                <svg aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            </div>
            <div style="padding:.75rem;border-bottom:1px solid var(--rl-border);flex-shrink:0">
              <label for="new-dm-search" class="sr-only">Search members</label>
              <input id="new-dm-search"
                     type="search"
                     placeholder="Find a member…"
                     class="input-field w-full"
                     autocomplete="off"
                     data-new-dm-target="searchInput"
                     data-action="input->new-dm#search">
            </div>
            <div class="new-dm-user-list" data-new-dm-target="userList" role="list"></div>
          </div>
        </div>

        <%# Main content %>
        <main id="main-content"
              style="flex:1;display:flex;flex-direction:column;overflow:hidden;outline:none"
              tabindex="-1"
              aria-label="Main content">
          <% if notice %>
            <div role="status" aria-live="polite" aria-atomic="true" class="flash flash-notice">
              <%= notice %>
            </div>
          <% end %>
          <% if alert %>
            <div role="alert" aria-live="assertive" aria-atomic="true" class="flash flash-alert">
              <%= alert %>
            </div>
          <% end %>

          <%# Mobile-only top bar — shown on non-channel pages that have no channel header %>
          <%# Channel pages (rooms/show) suppress this via content_for :channel_header %>
          <% unless content_for?(:channel_header) %>
            <div class="mobile-nav-bar" aria-label="Navigation" role="banner">
              <button class="btn-icon sidebar-toggle-btn"
                      aria-label="Open navigation"
                      aria-expanded="false"
                      data-action="click->sidebar#toggle">
                <svg aria-hidden="true" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
              </button>
              <span class="mobile-nav-bar-title"><%= yield(:title).presence || "REDLINE" %></span>
            </div>
          <% end %>

          <%= yield %>
        </main>

        <%# Search modal (hidden — will revisit later) %>
      </div>

    <% else %>
      <%# Unauthenticated — centered auth layout %>
      <main id="main-content" tabindex="-1">
        <% if notice %>
          <div role="status" aria-live="polite"
               style="position:fixed;top:1rem;right:1rem;z-index:50;padding:.75rem 1rem;
                      background:rgb(20,83,45);border:1px solid #15803d;color:#bbf7d0;
                      font-size:.875rem;border-radius:.75rem;max-width:24rem">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div role="alert" aria-live="assertive"
               style="position:fixed;top:1rem;right:1rem;z-index:50;padding:.75rem 1rem;
                      background:rgb(127,29,29);border:1px solid #b91c1c;color:#fecaca;
                      font-size:.875rem;border-radius:.75rem;max-width:24rem">
            <%= alert %>
          </div>
        <% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
