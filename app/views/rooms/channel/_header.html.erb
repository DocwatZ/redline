<%# Channel header — top bar with channel info, join button, and toggles %>
<header class="channel-header"
        role="banner"
        aria-label="<%= room.name %> channel header">

  <%# Left group: hamburger + channel name + status %>
  <div class="channel-header-left">
    <%# Mobile hamburger menu %>
    <button class="btn-icon sidebar-toggle-btn"
            aria-label="Open navigation"
            aria-expanded="false"
            data-action="click->sidebar#toggle">
      <svg aria-hidden="true" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <span class="text-xl" aria-hidden="true">
      <%= channel_icon_svg(room) %>
    </span>
    <div class="channel-header-info">
      <div class="channel-header-title-row">
        <h1 class="channel-header-title">
          <%= room.name %>
          <% if room.subchannel? %>
            <span class="text-xs text-muted font-normal">
              (subchannel of <%= room.parent.name %>)
            </span>
          <% end %>
        </h1>
        <%# Connection status dot %>
        <span id="channel-status-dot"
              class="channel-status-dot channel-status-connected"
              aria-label="Connected"
              role="status"></span>
      </div>
      <% if room.description.present? && !room.announcement? %>
        <p class="text-xs text-muted truncate"><%= room.description %></p>
      <% end %>
    </div>
  </div>

  <%# Right group: members + settings %>
  <div class="channel-header-right">
    <%# Members toggle %>
    <button class="btn-icon channel-members-toggle"
            aria-label="Toggle member list, <%= members.count %> members"
            aria-expanded="true"
            aria-controls="members-panel"
            data-action="click->channel#toggleMembers">
      <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span class="channel-members-count"><%= members.count %></span>
    </button>

    <%# Settings icon %>
    <%= link_to edit_room_path(room),
          class: "btn-icon channel-settings-btn",
          aria: { label: "Channel settings" } do %>
      <svg aria-hidden="true" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
    <% end %>

    <%# Device picker (voice channels only) %>
    <% if room.voice_channel? %>
      <div id="device-picker-modal" class="modal hidden" role="dialog" aria-modal="true" aria-label="Device Settings" style="display:none">
        <div class="modal-content" style="max-width:24rem">
          <div class="modal-header">
            <h2 class="text-sm font-semibold text-primary">Audio & Video Settings</h2>
            <button type="button" class="btn-icon" aria-label="Close device settings"
                    data-action="click->channel#closeDevicePicker">
              <svg aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="modal-body" style="display:flex;flex-direction:column;gap:1rem;padding:1rem">
            <div>
              <label class="text-xs font-medium text-muted block mb-1" for="dp-audioinput">Microphone</label>
              <select id="dp-audioinput" class="input-field w-full" data-device-kind="audioinput"></select>
            </div>
            <div>
              <label class="text-xs font-medium text-muted block mb-1" for="dp-audiooutput">Speaker</label>
              <select id="dp-audiooutput" class="input-field w-full" data-device-kind="audiooutput"></select>
            </div>
            <div>
              <label class="text-xs font-medium text-muted block mb-1" for="dp-videoinput">Camera</label>
              <select id="dp-videoinput" class="input-field w-full" data-device-kind="videoinput"></select>
            </div>
            <div class="flex gap-2 justify-end">
              <button type="button" class="btn btn-ghost" data-action="click->channel#closeDevicePicker">Cancel</button>
              <button type="button" class="btn btn-primary" data-action="click->channel#applyDevices">Apply</button>
            </div>
          </div>
        </div>
      </div>
      <button type="button" class="btn-icon" title="Device settings" aria-label="Open device settings"
              data-action="click->channel#openDevicePicker">
        <svg aria-hidden="true" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
        </svg>
      </button>
    <% end %>
  </div>
</header>
