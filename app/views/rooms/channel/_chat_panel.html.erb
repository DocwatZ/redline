<%# Chat panel — messages area + input %>
<%# On mobile for voice channels: slides up as bottom sheet %>
<%# On desktop for voice channels: right sidebar %>
<%# For chat-only channels: always visible as main content %>

<%# Pinned messages banner %>
<div id="pinned-banner" class="pinned-banner<%= ' hidden' unless @pinned_messages&.any? %>"
     role="region" aria-label="Pinned messages"
     <% unless @pinned_messages&.any? %>style="display:none"<% end %>>
  <div class="flex items-center gap-2 mb-1">
    <svg aria-hidden="true" width="12" height="12" fill="currentColor" viewBox="0 0 24 24">
      <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
    </svg>
    <span class="text-xs font-semibold" style="color:var(--rl-text-primary)">Pinned</span>
  </div>
  <% @pinned_messages&.each do |pm| %>
    <div class="pinned-message-item" data-pinned-msg-id="<%= pm.id %>">
      <span class="text-xs" style="color:var(--rl-text-muted)"><%= h(pm.user.display_name) %>:</span>
      <span class="text-xs" style="color:var(--rl-text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= h(pm.display_body.truncate(80)) %></span>
    </div>
  <% end %>
</div>

<%# Main messages area %>
<div id="messages"
     class="channel-messages"
     role="log"
     aria-live="polite"
     aria-label="Chat messages"
     aria-relevant="additions"
     data-controller="chat<%= ' e2ee' if room.e2ee? %>"
     data-chat-room-id-value="<%= room.id %>"
     data-chat-room-slug-value="<%= room.slug %>"
     data-chat-current-user-id-value="<%= current_user.id %>"
     <% if room.e2ee? %>
     data-e2ee-room-id-value="<%= room.id %>"
     data-e2ee-e2ee-enabled-value="true"
     <% end %>>

  <%# Skeleton loader — removed by chat_controller.js after initial messages load %>
  <% if messages.any? %>
    <%# Messages present; no skeleton needed — chat_controller will still call removeSkeleton safely %>
  <% else %>
    <div id="chat-skeleton" class="chat-skeleton" aria-hidden="true" aria-label="Loading messages">
      <% 5.times do |i| %>
        <div class="chat-skeleton-row">
          <div class="chat-skeleton-avatar"></div>
          <div class="chat-skeleton-lines">
            <div class="chat-skeleton-line" style="width:<%= [35, 55, 42, 60, 48][i % 5] %>%"></div>
            <div class="chat-skeleton-line" style="width:<%= [80, 65, 90, 70, 85][i % 5] %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if room.e2ee? %>
    <div id="e2ee-status-banner" class="channel-announcement" role="status" aria-live="polite"
         style="border-left:3px solid var(--rl-accent);margin-bottom:0.5rem">
      <div class="flex items-center gap-2">
        <span class="text-lg" aria-hidden="true">🔐</span>
        <div>
          <h2 class="font-semibold text-primary text-sm" style="margin:0">End-to-End Encrypted</h2>
          <p class="text-xs text-muted" style="margin:0.25rem 0 0">
            Messages in this channel are encrypted. Your key is being loaded&hellip;
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <% if room.announcement? && room.description.present? %>
    <div class="channel-announcement" role="region" aria-label="Announcement">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xl" aria-hidden="true">📢</span>
        <h2 class="font-semibold text-primary text-sm">Announcement</h2>
      </div>
      <div class="text-secondary text-sm leading-relaxed whitespace-pre-wrap">
        <%= room.description %>
      </div>
    </div>
  <% end %>

  <% if messages.empty? %>
    <div id="chat-empty-state"
         style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:2rem;text-align:center"
         role="status"
         aria-label="No messages yet">
      <svg aria-hidden="true" width="56" height="56" fill="none" viewBox="0 0 56 56"
           style="margin-bottom:1rem;opacity:.25">
        <rect width="56" height="56" rx="28" fill="var(--rl-surface-elevated)"/>
        <path d="M14 20a4 4 0 0 1 4-4h20a4 4 0 0 1 4 4v12a4 4 0 0 1-4 4H22l-8 4V20z"
              stroke="var(--rl-text-muted)" stroke-width="2" stroke-linejoin="round"/>
        <circle cx="21" cy="26" r="1.5" fill="var(--rl-text-muted)"/>
        <circle cx="28" cy="26" r="1.5" fill="var(--rl-text-muted)"/>
        <circle cx="35" cy="26" r="1.5" fill="var(--rl-text-muted)"/>
      </svg>
      <p style="font-size:.9375rem;font-weight:600;color:var(--rl-text-primary);margin:0 0 .25rem">
        No messages yet
      </p>
      <p style="font-size:.8125rem;color:var(--rl-text-muted);margin:0">
        Be the first to say something in <strong><%= room.name %></strong>!
      </p>
    </div>
  <% end %>

  <% messages.each do |message| %>
    <%= render "messages/message", message: message %>
  <% end %>

  <%# Typing indicator %>
  <div id="typing-indicator" class="typing-indicator" aria-live="polite" aria-atomic="true"></div>

  <%# Auto-scroll anchor %>
  <div id="messages-end" aria-hidden="true"></div>
</div>

<%# Message input %>
<% if room.chat? && room.member?(current_user) %>
  <div class="channel-message-compose"
       data-controller="message-input"
       aria-label="Compose message"
       data-action="dragover->message-input#dragOver drop->message-input#drop dragleave->message-input#dragLeave">
    <%# Reply-to banner (hidden until a reply is triggered) %>
    <div class="message-reply-banner hidden"
         data-message-input-target="replyBanner"
         role="status"
         aria-live="polite">
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <svg aria-hidden="true" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6M3 10l6-6"/>
        </svg>
        <span class="text-xs text-muted">Replying to</span>
        <span class="text-xs font-semibold text-primary" data-message-input-target="replyAuthor"></span>
        <span class="text-xs text-secondary truncate" data-message-input-target="replyPreview"></span>
      </div>
      <button type="button" class="btn-icon" style="min-height:1.5rem;min-width:1.5rem;padding:.25rem"
              aria-label="Cancel reply"
              data-action="click->message-input#clearReply">
        <svg aria-hidden="true" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <%# File preview strip (hidden until files are selected) %>
    <div class="message-file-preview hidden"
         data-message-input-target="filePreview"
         aria-live="polite"
         aria-label="Selected files"></div>

    <form id="message-form"
          method="post"
          action="<%= room_messages_path(room) %>"
          data-action="submit->message-input#send"
          data-turbo="false"
          aria-label="Send a message to <%= room.name %>">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <%# Hidden file input %>
      <input type="file"
             id="message-file-input"
             multiple
             accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.txt,.zip"
             class="sr-only"
             aria-label="Attach files"
             data-message-input-target="fileInput"
             data-action="change->message-input#filesSelected">

      <div class="channel-compose-row">
        <%# Attach button %>
        <button type="button"
                class="btn-icon channel-attach-btn"
                aria-label="Attach file"
                title="Attach file"
                data-action="click->message-input#openFilePicker">
          <svg aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
          </svg>
        </button>

        <div class="channel-compose-field">
          <label for="message-body" class="sr-only">
            Message <%= room.name %>
          </label>
          <textarea id="message-body"
                    name="message[body]"
                    rows="1"
                    maxlength="4000"
                    placeholder="Message <%= room.display_icon %><%= room.name %>"
                    class="input-field w-full resize-none min-h-[44px] max-h-48 py-2.5 leading-snug
                           scrollbar-thin overflow-y-auto"
                    aria-label="Message input"
                    aria-describedby="message-hint"
                    data-message-input-target="field"
                    data-action="keydown->message-input#handleKeydown
                                 input->message-input#autoResize"></textarea>
          <span id="message-hint" class="sr-only">
            Press Enter to send, Shift+Enter for new line
          </span>
        </div>

        <%# Emoji button %>
        <button type="button"
                class="btn-icon channel-emoji-btn"
                aria-label="Insert emoji"
                title="Insert emoji"
                data-action="click->message-input#openEmojiPicker">
          <svg aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <path stroke-linecap="round" d="M8 13s1.5 2 4 2 4-2 4-2"/>
            <line x1="9" y1="9" x2="9.01" y2="9"/>
            <line x1="15" y1="9" x2="15.01" y2="9"/>
          </svg>
        </button>

        <button type="submit"
                class="btn-accent channel-send-btn"
                aria-label="Send message">
          <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
          </svg>
        </button>
      </div>
    </form>
  </div>
<% end %>
