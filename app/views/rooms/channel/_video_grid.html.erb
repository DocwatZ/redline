<%# Video/Voice participant grid — shown when user joins a voice channel %>
<% if room.voice_channel? %>
  <%# Pre-call modal (shown before joining a voice call) %>
  <div id="precall-modal" class="modal hidden" role="dialog" aria-modal="true" aria-label="Ready to join?" style="display:none">
    <div class="modal-content" style="max-width:28rem">
      <div class="modal-header">
        <h2 class="text-sm font-semibold text-primary">Ready to join <%= h(room.name) %>?</h2>
      </div>
      <div style="padding:1rem;display:flex;flex-direction:column;gap:1rem">
        <div style="position:relative;background:#000;border-radius:var(--rl-radius);overflow:hidden;aspect-ratio:16/9;max-height:180px">
          <video id="precall-preview" autoplay muted playsinline
                 style="width:100%;height:100%;object-fit:cover"></video>
          <div id="precall-no-video" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.75rem;text-align:center;padding:.5rem">
            Camera not available
          </div>
        </div>
        <div>
          <label class="text-xs font-medium text-muted block mb-1" for="precall-audioinput">Microphone</label>
          <select id="precall-audioinput" class="input-field w-full"></select>
        </div>
        <div>
          <label class="text-xs font-medium text-muted block mb-1" for="precall-videoinput">Camera</label>
          <select id="precall-videoinput" class="input-field w-full"></select>
        </div>
        <div class="flex gap-2 justify-end">
          <button type="button" class="btn btn-ghost" data-action="click->channel#cancelPrecall">Cancel</button>
          <button type="button" class="btn-accent" style="padding:.5rem 1.25rem" data-action="click->channel#confirmJoin">
            Join Now
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="call-panel"
       class="channel-call-panel hidden"
       aria-live="polite"
       aria-label="Voice channel panel">

    <%# Loading skeleton (shown during connect, hidden after) %>
    <div id="call-loading" class="channel-call-loading hidden" aria-label="Connecting to voice channel">
      <div class="call-loading-spinner" aria-hidden="true"></div>
      <span class="text-sm text-muted">Connecting...</span>
    </div>

    <%# Subchannels list %>
    <% if subchannels&.any? %>
      <div class="channel-subchannels">
        <h3 class="text-xs font-semibold text-muted uppercase tracking-wider mb-2">Subchannels</h3>
        <div class="flex flex-wrap gap-2">
          <% subchannels.each do |sub| %>
            <%= link_to room_path(sub),
                  class: "channel-subchannel-link",
                  aria: { label: "Join subchannel #{sub.name}" } do %>
              <span aria-hidden="true"><%= channel_icon_svg(sub) %></span>
              <span class="text-secondary"><%= sub.name %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div id="call-participants" class="channel-participants-grid" role="list" aria-label="Channel participants">
      <%# Populated by LiveKit JS %>
    </div>
  </div>
<% end %>
