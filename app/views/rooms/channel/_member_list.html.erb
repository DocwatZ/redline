<%# Member list panel — right sidebar on desktop, hidden on mobile %>
<aside id="members-panel"
       class="channel-members-panel"
       aria-label="Channel members"
       data-controller="member-role"
       data-member-role-room-slug-value="<%= room.slug %>">

  <% current_membership = room.membership_for(current_user) %>
  <div class="p-3">
    <h2 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">
      Members — <%= members.count %>
    </h2>
    <ul role="list" class="space-y-1">
      <% members.each do |member| %>
        <% membership = room.membership_for(member) %>
        <li style="display:flex;align-items:center;gap:.25rem">
          <%= link_to user_path(member),
                class: "channel-member-item",
                style: "flex:1;min-width:0",
                aria: { label: "#{member.display_name}, #{member.status}" } do %>
            <div class="relative flex-shrink-0">
              <span class="w-7 h-7 rounded-full flex items-center justify-center
                           text-white text-xs font-bold"
                    style="background-color: <%= member.avatar_color %>"
                    aria-hidden="true">
                <%= member.initials %>
              </span>
              <span class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full border-2 border-base
                           <%= member.online? ? 'bg-green-500' : 'bg-gray-500' %>"
                    aria-hidden="true"></span>
            </div>
            <span class="truncate text-secondary"><%= member.display_name %></span>
            <span class="member-role-badge ml-auto text-xs text-accent" aria-label="<%= membership&.role %>">
              <% if membership&.admin? %>★<% elsif membership&.role == "moderator" %>◆<% end %>
            </span>
          <% end %>
          <%# Role management — only visible to admins, not for self %>
          <% if current_membership&.admin? && member != current_user %>
            <div style="display:flex;flex-direction:column;gap:.125rem;flex-shrink:0">
              <% unless membership&.role == "admin" %>
                <button class="btn-icon"
                        style="font-size:.625rem;padding:.1rem .25rem;min-height:auto;color:var(--rl-text-muted)"
                        title="Promote to Admin"
                        aria-label="Promote <%= member.display_name %> to admin"
                        data-action="click->member-role#setRole"
                        data-user-id="<%= member.id %>"
                        data-role="admin">↑A</button>
              <% end %>
              <% if membership&.role == "admin" %>
                <button class="btn-icon"
                        style="font-size:.625rem;padding:.1rem .25rem;min-height:auto;color:var(--rl-text-muted)"
                        title="Demote to Moderator"
                        aria-label="Demote <%= member.display_name %> to moderator"
                        data-action="click->member-role#setRole"
                        data-user-id="<%= member.id %>"
                        data-role="moderator">↓M</button>
              <% elsif membership&.role == "moderator" %>
                <button class="btn-icon"
                        style="font-size:.625rem;padding:.1rem .25rem;min-height:auto;color:var(--rl-text-muted)"
                        title="Demote to Member"
                        aria-label="Demote <%= member.display_name %> to member"
                        data-action="click->member-role#setRole"
                        data-user-id="<%= member.id %>"
                        data-role="member">↓</button>
              <% else %>
                <button class="btn-icon"
                        style="font-size:.625rem;padding:.1rem .25rem;min-height:auto;color:var(--rl-text-muted)"
                        title="Promote to Moderator"
                        aria-label="Promote <%= member.display_name %> to moderator"
                        data-action="click->member-role#setRole"
                        data-user-id="<%= member.id %>"
                        data-role="moderator">↑M</button>
              <% end %>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <%# Leave channel %>
  <div class="p-3 border-t border-border mt-2">
    <%= button_to leave_room_path(room), method: :delete,
          class: "btn-ghost w-full text-sm text-danger hover:bg-red-900/20",
          aria: { label: "Leave #{room.name} channel" } do %>
      Leave Channel
    <% end %>
  </div>
</aside>
