<%# Control bar — persistent bottom bar for voice/video controls + chat toggle %>
<%# On mobile: always visible at bottom; On desktop: visible when in call %>
<% if room.voice_channel? %>
  <div id="channel-control-bar"
       class="channel-control-bar hidden"
       role="toolbar"
       aria-label="Channel controls">

    <button id="toggle-mic"
            class="control-btn"
            aria-label="Toggle microphone"
            aria-pressed="false"
            data-action="click->channel#toggleMic">
      <svg aria-hidden="true" class="control-btn-icon" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
        <path d="M19 10v2a7 7 0 01-14 0v-2"/>
        <line x1="12" y1="19" x2="12" y2="23"/>
        <line x1="8" y1="23" x2="16" y2="23"/>
      </svg>
      <span class="control-btn-label">Mute</span>
    </button>

    <button id="toggle-camera"
            class="control-btn hidden"
            aria-label="Toggle camera"
            aria-pressed="false"
            data-action="click->channel#toggleCamera">
      <svg aria-hidden="true" class="control-btn-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.854v6.292a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
      </svg>
      <span class="control-btn-label">Camera</span>
    </button>

    <button id="toggle-deafen"
            class="control-btn"
            aria-label="Toggle deafen"
            aria-pressed="false"
            data-action="click->channel#toggleDeafen">
      <svg aria-hidden="true" class="control-btn-icon" fill="currentColor" viewBox="0 0 24 24">
        <path d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728M9.172 14.828a4 4 0 010-5.656m5.656 0a4 4 0 010 5.656"/>
        <circle cx="12" cy="12" r="1.5"/>
      </svg>
      <span class="control-btn-label">Deafen</span>
    </button>

    <button id="toggle-screen-share"
            class="control-btn hidden"
            aria-label="Toggle screen sharing"
            aria-pressed="false"
            data-action="click->channel#toggleScreenShare">
      <svg aria-hidden="true" class="control-btn-icon" fill="currentColor" viewBox="0 0 24 24">
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <path d="M8 21h8M12 17v4"/>
      </svg>
      <span class="control-btn-label">Share</span>
    </button>

    <%# Chat toggle for mobile (opens bottom sheet) %>
    <button id="toggle-chat-btn"
            class="control-btn control-btn-chat"
            aria-label="Toggle chat panel"
            aria-pressed="false"
            data-action="click->bottom-sheet#toggle">
      <svg aria-hidden="true" class="control-btn-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <span class="control-btn-label">Chat</span>
    </button>

    <button id="leave-call"
            class="control-btn control-btn-danger"
            aria-label="Leave voice channel"
            data-action="click->channel#leaveCall">
      <svg aria-hidden="true" class="control-btn-icon" fill="currentColor" viewBox="0 0 24 24">
        <path d="M16 8l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M5 3a2 2 0 00-2 2v1c0 8.284 6.716 15 15 15h1a2 2 0 002-2v-3.28a1 1 0 00-.684-.948l-4.493-1.498a1 1 0 00-1.21.502l-1.13 2.257a11.042 11.042 0 01-5.516-5.517l2.257-1.128a1 1 0 00.502-1.21L9.228 3.683A1 1 0 008.279 3H5z"/>
      </svg>
      <span class="control-btn-label">Leave</span>
    </button>
  </div>
<% end %>
