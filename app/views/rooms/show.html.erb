<% content_for :title, @room.name %>
<% content_for :channel_header, true %>

<%#
  Unified Channel Layout — mobile-first, responsive
  State managed by channel_controller.js
  Voice channels use bottom control bar + bottom sheet chat
%>
<div class="channel-layout"
     data-controller="channel bottom-sheet"
     data-channel-room-slug-value="<%= @room.slug %>"
     data-channel-voice-value="<%= @room.voice_channel? %>"
     data-channel-token-url-value="<%= @room.voice_channel? ? livekit_token_room_path(@room) : '' %>"
     data-bottom-sheet-panel-value="in-call-chat-panel">

  <%# Channel header %>
  <%= render "rooms/channel/header", room: @room, members: @members %>

  <%# Main content area %>
  <div class="channel-body">

    <%# Left: active content (video grid + chat) %>
    <div class="channel-canvas">

      <%# Video/Voice grid (voice channels only) %>
      <%= render "rooms/channel/video_grid", room: @room, subchannels: @subchannels %>

      <%# Chat messages + input %>
      <div id="channel-chat-wrapper" class="channel-chat-wrapper">
        <%= render "rooms/channel/chat_panel", room: @room, messages: @messages %>
      </div>
    </div>

    <%# Right sidebar: member list (desktop) %>
    <%= render "rooms/channel/member_list", room: @room, members: @members %>

    <%# In-call chat (bottom sheet on mobile, sidebar on desktop) %>
    <%= render "rooms/channel/in_call_chat",
               room: @room,
               in_call_messages: @in_call_messages %>
  </div>

  <%# Bottom control bar (voice channels) %>
  <%= render "rooms/channel/control_bar", room: @room %>
</div>
