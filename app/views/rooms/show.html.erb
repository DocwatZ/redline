<% content_for :title, @room.name %>

<div class="flex h-full overflow-hidden">

  <%# Chat / Voice Main Area %>
  <div class="flex flex-col flex-1 overflow-hidden">

    <%# Room header %>
    <header class="h-14 border-b border-border px-4 flex items-center gap-3 flex-shrink-0"
            role="banner"
            aria-label="<%= @room.name %> room header">
      <span class="text-xl" aria-hidden="true">
        <%= @room.voice? ? "🔊" : (@room.announcement? ? "📢" : "#") %>
      </span>
      <div class="flex-1 min-w-0">
        <h1 class="font-semibold text-primary truncate"><%= @room.name %></h1>
        <% if @room.description.present? && !@room.announcement? %>
          <p class="text-xs text-muted truncate"><%= @room.description %></p>
        <% end %>
      </div>

      <%# Voice/Video call button for voice rooms %>
      <% if @room.voice? %>
        <button id="join-call-btn"
                class="btn-accent flex items-center gap-2 text-sm"
                aria-label="Join voice call in <%= @room.name %>"
                data-controller="livekit"
                data-livekit-token-url-value="<%= livekit_token_room_path(@room) %>"
                data-action="click->livekit#joinCall">
          <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Join Call
        </button>
      <% end %>

      <%# Members count %>
      <button class="flex items-center gap-1 text-muted hover:text-primary text-sm transition-colors
                     rounded focus:outline-none focus:ring-2 focus:ring-accent"
              aria-label="Toggle member list, <%= @members.count %> members"
              aria-expanded="true"
              aria-controls="members-panel"
              data-action="click->sidebar#toggle">
        <svg aria-hidden="true" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span><%= @members.count %></span>
      </button>
    </header>

    <%# Voice call panel (hidden by default) %>
    <% if @room.voice? %>
      <div id="call-panel"
           class="hidden bg-surface-elevated border-b border-border p-4"
           aria-live="polite"
           aria-label="Voice call panel">
        <div id="call-participants" class="flex flex-wrap gap-3" role="list" aria-label="Call participants">
          <%# Populated by LiveKit JS %>
        </div>
        <div class="flex gap-3 mt-4" role="toolbar" aria-label="Call controls">
          <button id="toggle-mic"
                  class="btn-ghost flex items-center gap-2 text-sm"
                  aria-label="Toggle microphone"
                  aria-pressed="true"
                  data-action="click->livekit#toggleMic">
            <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
              <path d="M19 10v2a7 7 0 01-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
            Mute
          </button>
          <button id="leave-call"
                  class="btn-danger flex items-center gap-2 text-sm"
                  aria-label="Leave voice call"
                  data-action="click->livekit#leaveCall">
            <svg aria-hidden="true" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 8l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2M5 3a2 2 0 00-2 2v1c0 8.284 6.716 15 15 15h1a2 2 0 002-2v-3.28a1 1 0 00-.684-.948l-4.493-1.498a1 1 0 00-1.21.502l-1.13 2.257a11.042 11.042 0 01-5.516-5.517l2.257-1.128a1 1 0 00.502-1.21L9.228 3.683A1 1 0 008.279 3H5z"/>
            </svg>
            Leave
          </button>
        </div>
      </div>
    <% end %>

    <%# Messages area %>
    <div id="messages"
         class="flex-1 overflow-y-auto p-4 space-y-1"
         role="log"
         aria-live="polite"
         aria-label="Chat messages"
         aria-relevant="additions"
         data-controller="chat"
         data-chat-room-id-value="<%= @room.id %>">

      <% if @room.announcement? && @room.description.present? %>
        <div class="bg-surface-elevated border border-border rounded-lg p-4 mb-4"
             role="region"
             aria-label="Announcement">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xl" aria-hidden="true">📢</span>
            <h2 class="font-semibold text-primary text-sm">Announcement</h2>
          </div>
          <div class="text-secondary text-sm leading-relaxed whitespace-pre-wrap">
            <%= @room.description %>
          </div>
        </div>
      <% end %>

      <% @messages.each do |message| %>
        <%= render "messages/message", message: message %>
      <% end %>

      <%# Auto-scroll anchor %>
      <div id="messages-end" aria-hidden="true"></div>
    </div>

    <%# Message input (only for text rooms) %>
    <% if @room.text? && @room.member?(current_user) %>
      <div class="border-t border-border p-3 flex-shrink-0">
        <form id="message-form"
              data-controller="message-input"
              data-action="submit->message-input#send"
              aria-label="Send a message to <%= @room.name %>">
          <div class="flex items-end gap-2">
            <div class="flex-1 relative">
              <label for="message-body" class="sr-only">
                Message <%= @room.name %>
              </label>
              <textarea id="message-body"
                        name="body"
                        rows="1"
                        maxlength="4000"
                        placeholder="Message #<%= @room.name %>"
                        class="input-field w-full resize-none min-h-[44px] max-h-48 py-2.5 pr-12 leading-snug
                               scrollbar-thin overflow-y-auto"
                        aria-label="Message input"
                        aria-describedby="message-hint"
                        data-message-input-target="field"
                        data-action="keydown->message-input#handleKeydown
                                     input->message-input#autoResize"></textarea>
              <span id="message-hint" class="sr-only">
                Press Enter to send, Shift+Enter for new line
              </span>
            </div>
            <button type="submit"
                    class="btn-accent w-11 h-11 flex items-center justify-center flex-shrink-0
                           disabled:opacity-50 disabled:cursor-not-allowed"
                    aria-label="Send message">
              <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
              </svg>
            </button>
          </div>
        </form>
      </div>
    <% end %>
  </div>

  <%# Right sidebar: members %>
  <aside id="members-panel"
         class="w-56 border-l border-border flex-shrink-0 overflow-y-auto"
         aria-label="Room members">
    <div class="p-3">
      <h2 class="text-xs font-semibold text-muted uppercase tracking-wider mb-3">
        Members — <%= @members.count %>
      </h2>
      <ul role="list" class="space-y-1">
        <% @members.each do |member| %>
          <li>
            <%= link_to user_path(member),
                  class: "flex items-center gap-2 px-2 py-1.5 rounded hover:bg-surface-elevated
                          transition-colors text-sm
                          focus:outline-none focus:ring-2 focus:ring-accent focus:ring-inset",
                  aria: { label: "#{member.display_name}, #{member.status}" } do %>
              <div class="relative flex-shrink-0">
                <span class="w-7 h-7 rounded-full flex items-center justify-center
                             text-white text-xs font-bold"
                      style="background-color: <%= member.avatar_color %>"
                      aria-hidden="true">
                  <%= member.initials %>
                </span>
                <span class="absolute -bottom-0.5 -right-0.5 w-2.5 h-2.5 rounded-full border-2 border-base
                             <%= member.online? ? 'bg-green-500' : 'bg-gray-500' %>"
                      aria-hidden="true"></span>
              </div>
              <span class="truncate text-secondary"><%= member.display_name %></span>
              <% membership = @room.membership_for(member) %>
              <% if membership&.admin? %>
                <span class="ml-auto text-xs text-accent" aria-label="admin">★</span>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <%# Leave room %>
    <div class="p-3 border-t border-border mt-2">
      <%= button_to leave_room_path(@room), method: :delete,
            class: "btn-ghost w-full text-sm text-danger hover:bg-red-900/20",
            aria: { label: "Leave #{@room.name} room" } do %>
        Leave Room
      <% end %>
    </div>
  </aside>
</div>
