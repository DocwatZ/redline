<% content_for :title, "Search" %>

<div style="max-width:48rem;margin:0 auto;padding:2rem 1rem">
  <h1 style="font-size:1.25rem;font-weight:600;color:var(--rl-text-primary);margin-bottom:1rem">Search</h1>

  <%= form_tag search_path, method: :get do %>
    <div style="display:flex;gap:.5rem;margin-bottom:1.5rem">
      <%= text_field_tag :q, @query, placeholder: "Search messages and people…",
            class: "input-field", style: "flex:1", autofocus: true %>
      <%= submit_tag "Search", class: "btn btn-primary" %>
    </div>
  <% end %>

  <% if @query.length >= 2 %>
    <% if @users.any? %>
      <section style="margin-bottom:1.5rem">
        <h2 style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--rl-text-muted);margin-bottom:.5rem">People</h2>
        <% @users.each do |user| %>
          <%= link_to user_path(user), class: "search-result-item" do %>
            <div style="width:2rem;height:2rem;border-radius:50%;background:<%= user.avatar_color %>;display:flex;align-items:center;justify-content:center;font-size:.7rem;color:#fff;flex-shrink:0">
              <%= user.initials %>
            </div>
            <div>
              <div style="font-size:.875rem;font-weight:500;color:var(--rl-text-primary)"><%= user.display_name %></div>
              <div style="font-size:.75rem;color:var(--rl-text-muted)">@<%= user.username %></div>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>

    <% if @messages.any? %>
      <section>
        <h2 style="font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--rl-text-muted);margin-bottom:.5rem">Messages</h2>
        <% @messages.each do |msg| %>
          <%= link_to room_path(msg.room), class: "search-result-item" do %>
            <div style="flex:1;min-width:0">
              <div style="font-size:.75rem;color:var(--rl-text-muted)">#<%= msg.room.name %> · <%= msg.user.display_name %></div>
              <div style="font-size:.875rem;color:var(--rl-text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= msg.display_body %></div>
            </div>
          <% end %>
        <% end %>
      </section>
    <% elsif @users.empty? %>
      <p style="color:var(--rl-text-muted);font-size:.875rem">No results for "<%= @query %>"</p>
    <% end %>
  <% end %>
</div>
