<% content_for :title, "Join #{@invite.room.name}" %>

<div style="display:flex;align-items:center;justify-content:center;min-height:100vh;padding:1rem">
  <div style="background:var(--rl-surface-elevated);border:1px solid var(--rl-border);border-radius:var(--rl-radius-lg);padding:2rem;width:min(400px,100%);text-align:center">
    <h1 style="font-size:1.25rem;font-weight:600;color:var(--rl-text-primary);margin-bottom:.5rem">
      You've been invited!
    </h1>
    <p style="color:var(--rl-text-secondary);margin-bottom:1.5rem">
      Join <strong>#<%= @invite.room.name %></strong>
    </p>
    <%= button_to "Accept Invite", accept_invite_path(@invite.code),
          method: :post,
          class: "btn btn-primary",
          style: "width:100%" %>
    <%= link_to "Cancel", root_path, class: "btn btn-ghost", style: "display:block;margin-top:.5rem" %>
  </div>
</div>
