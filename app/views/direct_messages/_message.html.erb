<% is_own = dm.sender == current_user %>
<article id="dm-<%= dm.id %>"
         class="flex gap-3 py-1 px-2 rounded hover:bg-surface-elevated/50"
         aria-label="Message from <%= dm.sender.display_name %> at <%= dm.created_at.strftime('%H:%M') %>">
  <div class="flex-shrink-0 mt-0.5" aria-hidden="true">
    <div class="w-8 h-8 rounded-full flex items-center justify-center
                text-white text-xs font-bold"
         style="background-color: <%= dm.sender.avatar_color %>">
      <%= dm.sender.initials %>
    </div>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-baseline gap-2 flex-wrap">
      <span class="font-semibold text-sm text-primary"><%= dm.sender.display_name %></span>
      <time datetime="<%= dm.created_at.iso8601 %>"
            class="text-xs text-muted"
            title="<%= dm.created_at.strftime('%B %-d, %Y at %H:%M UTC') %>">
        <%= dm.created_at.strftime('%H:%M') %>
      </time>
    </div>
    <div class="text-sm text-secondary mt-0.5 leading-relaxed whitespace-pre-wrap break-words
                <%= "italic text-muted" if dm.deleted? %>"
         <% unless dm.deleted? %>data-controller="link-preview"<% end %>>
      <%= dm.display_body %>
    </div>
  </div>
</article>
