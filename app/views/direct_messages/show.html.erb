<% content_for :title, "DM · #{@partner.display_name}" %>

<div class="page-layout">
  <%# Header %>
  <header class="page-header" role="banner">
    <%# Mobile hamburger %>
    <button class="btn-icon sidebar-toggle-btn"
            aria-label="Open navigation"
            aria-expanded="false"
            data-action="click->sidebar#toggle">
      <svg aria-hidden="true" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <div class="w-8 h-8 rounded-full flex items-center justify-center
                text-white text-xs font-bold flex-shrink-0"
         style="background-color: <%= @partner.avatar_color %>"
         aria-hidden="true">
      <%= @partner.initials %>
    </div>
    <div class="flex-1 min-w-0">
      <h1 class="font-semibold text-primary truncate" style="font-size:1rem"><%= @partner.display_name %></h1>
      <p class="text-xs text-muted capitalize"><%= @partner.status %></p>
    </div>
    <% if @partner.email.present? %>
      <span class="text-xs text-muted sm:block hidden"><%= @partner.email %></span>
    <% end %>
  </header>

  <%# Messages %>
  <div id="dm-messages"
       class="scroll-area"
       role="log"
       aria-live="polite"
       aria-label="Direct messages with <%= @partner.display_name %>"
       aria-relevant="additions"
       data-controller="dm-chat"
       data-dm-chat-partner-id-value="<%= @partner.id %>"
       data-dm-chat-current-user-id-value="<%= current_user.id %>">

    <% if @messages.empty? %>
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;padding:2rem" role="status">
        <div class="w-16 h-16 rounded-full flex items-center justify-center text-white font-bold mb-4"
             style="background-color: <%= @partner.avatar_color %>; font-size:1.5rem"
             aria-hidden="true">
          <%= @partner.initials %>
        </div>
        <h2 class="text-lg font-semibold text-primary"><%= @partner.display_name %></h2>
        <p class="text-muted text-sm mt-1">This is the beginning of your conversation.</p>
      </div>
    <% end %>

    <% @messages.each do |dm| %>
      <%= render "direct_messages/message", dm: dm, current_user: current_user,
                 last_read_sent_id: @last_read_sent_id %>
    <% end %>

    <div id="dm-messages-end" aria-hidden="true"></div>
  </div>

  <%# Input %>
  <div class="channel-message-compose"
       data-controller="dm-input"
       aria-label="Compose direct message"
       data-action="dragover->dm-input#dragOver drop->dm-input#drop dragleave->dm-input#dragLeave">
    <%# Reply-to banner (hidden until a reply is triggered) %>
    <div class="message-reply-banner hidden"
         data-dm-input-target="replyBanner"
         role="status"
         aria-live="polite">
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <svg aria-hidden="true" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6M3 10l6-6"/>
        </svg>
        <span class="text-xs text-muted">Replying to</span>
        <span class="text-xs font-semibold text-primary" data-dm-input-target="replyAuthor"></span>
        <span class="text-xs text-secondary truncate" data-dm-input-target="replyPreview"></span>
      </div>
      <button type="button" class="btn-icon" style="min-height:1.5rem;min-width:1.5rem;padding:.25rem"
              aria-label="Cancel reply"
              data-action="click->dm-input#clearReply">
        <svg aria-hidden="true" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <%# File preview strip (hidden until files are selected) %>
    <div class="message-file-preview hidden"
         data-dm-input-target="filePreview"
         aria-live="polite"
         aria-label="Selected files"></div>

    <form id="dm-form"
          method="post"
          action="<%= user_direct_messages_path(@partner) %>"
          data-action="submit->dm-input#send"
          data-turbo="false"
          aria-label="Send a direct message to <%= @partner.display_name %>">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <%# Hidden file input %>
      <input type="file"
             id="dm-file-input"
             multiple
             accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.txt,.zip"
             class="sr-only"
             aria-label="Attach files"
             data-dm-input-target="fileInput"
             data-action="change->dm-input#filesSelected">

      <div class="channel-compose-row">
        <%# Attach button %>
        <button type="button"
                class="btn-icon channel-attach-btn"
                aria-label="Attach file"
                title="Attach file"
                data-action="click->dm-input#openFilePicker">
          <svg aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
          </svg>
        </button>

        <div class="channel-compose-field">
          <label for="dm-body" class="sr-only">
            Message <%= @partner.display_name %>
          </label>
          <textarea id="dm-body"
                    name="direct_message[body]"
                    rows="1"
                    maxlength="4000"
                    placeholder="Message <%= @partner.display_name %>"
                    class="input-field w-full resize-none min-h-[44px] max-h-48 py-2.5 leading-snug
                           scrollbar-thin overflow-y-auto"
                    aria-label="Direct message input"
                    aria-describedby="dm-hint"
                    data-dm-input-target="field"
                    data-action="keydown->dm-input#handleKeydown
                                 input->dm-input#autoResize"></textarea>
          <span id="dm-hint" class="sr-only">Press Enter to send, Shift+Enter for new line</span>
        </div>

        <%# Emoji button %>
        <button type="button"
                class="btn-icon channel-emoji-btn"
                aria-label="Insert emoji"
                title="Insert emoji"
                data-action="click->dm-input#openEmojiPicker">
          <svg aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <path stroke-linecap="round" d="M8 13s1.5 2 4 2 4-2 4-2"/>
            <line x1="9" y1="9" x2="9.01" y2="9"/>
            <line x1="15" y1="9" x2="15.01" y2="9"/>
          </svg>
        </button>

        <button type="submit"
                class="btn-accent channel-send-btn"
                aria-label="Send direct message">
          <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
          </svg>
        </button>
      </div>
    </form>
  </div>
</div>
